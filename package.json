{
  "name": "local-http-fs-server",
  "version": "1.0.0-b1",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "bun build --compile --minify src/index.ts --outfile dist/$npm_package_name-$npm_package_version",
    "build:linux-x64": "bun build --compile --minify src/index.ts --target=bun-linux-x64 --outfile dist/$npm_package_name-$npm_package_version-linux-x64",
    "build:linux-arm64": "bun build --compile --minify src/index.ts --target=bun-linux-arm64 --outfile dist/$npm_package_name-$npm_package_version-linux-arm64",
    "build:windows-x64": "bun build --compile --minify src/index.ts --target=bun-windows-x64 --outfile dist/$npm_package_name-$npm_package_version-windows-x64",
    "build:darwin-x64": "bun build --compile --minify src/index.ts --target=bun-darwin-x64 --outfile dist/$npm_package_name-$npm_package_version-darwin-x64",
    "build:darwin-arm64": "bun build --compile --minify src/index.ts --target=bun-darwin-arm64 --outfile dist/$npm_package_name-$npm_package_version-darwin-arm64",
    "build:all": "npm run build:linux-x64 && npm run build:linux-arm64 && npm run build:windows-x64 && npm run build:darwin-x64 && npm run build:darwin-arm64",
    "test": "bun test tests/"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3"
  },
  "module": "src/index.ts",
  "private": true,
  "peerDependencies": {
    "typescript": "^5"
  }
}
